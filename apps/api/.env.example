# Localhost is correct for cargo run on the host. Docker sqlx-prepare briefly renames .env to
# .env.koro_prepare_bak so compose DATABASE_URL (postgres service) is used; it is restored after.
DATABASE_URL=postgres://<user>:<password>@localhost:5432/<db>
PORT=<port_number>

# MinIO (optional; image uploads disabled if unset)
MINIO_ENDPOINT=<endpoint_url>
MINIO_ACCESS_KEY=<minio_access_key>
MINIO_SECRET_KEY=<minio_secret_key>
MINIO_BUCKET=<minio_bucket>
